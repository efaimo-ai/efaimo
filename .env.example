# efaimo secrets, only needed for the two commands that call a model API.
# Copy this file to `.env` (which is gitignored) and paste your key after the =.
# A real shell environment variable always overrides what is set here.

# Claude models: `efaimo test --live --model claude-...` and `efaimo weigh --anthropic`
ANTHROPIC_API_KEY=

# GPT models: `efaimo test --live --model gpt-...`
OPENAI_API_KEY=
